<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Arjun Bishnoi</title>
  <style>
    /* Basic Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* Body styling (mimics OpenAI's neutral look) */
    body {
      background-color: #000000; /* Similar to OpenAI's clean background */
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #ffffff;
      line-height: 1.6;
    }

    /* Header with logo and contact link */
    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
    }

    .logo {
      font-size: 24px;
      font-weight: 700;
      color: #ffffff;
      text-decoration: none;
    }

    nav a {
      font-size: 16px;
      text-decoration: none;
      padding: 8px 20px;
      color: white;
      background-color: #1f1f1f;
      font-weight: 500;
      border-radius: 400px;
      transition: all 0.3s ease;
    }

    nav a:hover {
        background-color: #333333;
    }

    /* Layout container for sidebar and main content */
    .container {
      display: flex;
      min-height: calc(100vh - 70px); /* Adjust based on header height */
    }

    /* Sidebar styling */
    .sidebar {
      width: 220px;
      padding: 20px;
    }

    .sidebar ul {
      list-style: none;
      margin-left: 20px;
      max-width: 100px;
      margin-top: 25px;
      overflow:hidden;
    }

    .sidebar ul li {
      margin-bottom: 10px;
     
    }

    .sidebar ul li a {
      font-size: 13px;
      transition: all 0.3s ease;
      color: white;
      padding: 8px 60px;
      border-radius: 10px;
      padding-left: 10px;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .sidebar ul li a:hover {
      background-color: #333333;
    }

    /* Main content area */
    .main-content {
      flex: 1;
      padding: 40px;
    }

    /* Example header for main content */
    .main-content h1 {
      font-size: 2.5em;
      margin-bottom: 20px;
    }

    .main-content p {
      font-size: 1.2em;
    }
  </style>
</head>
<body>
  <!-- Top Navigation -->
  <header>
    <a href="#" class="logo">Arjun Bishnoi</a>
    <nav>
      <a href="mailto:contact@arjunbishnoi.com">Contact</a>
    </nav>
  </header>

  <!-- Page Layout: Sidebar + Main Content -->
  <div class="container">
    <aside class="sidebar">
      <ul>
        <li><a href="#portfolio">Portfolio</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#others">Others</a></li>
      </ul>
    </aside>
    <div class="main-content">
      <h1>Stay Tuned</h1>
    </div>
  </div>
</body>
</html>
