<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Arjun Bishnoi - Full Stack Developer & UI/UX Designer</title>
  <style>
    /* Basic Reset */
    * {
      margin: 0;
      padding: 0;
    }

    html {
        font-family: Soehne, system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
        font-size: 16px;
        line-height: 24px;
        text-align: start;
        min-height: 100vh;
        background-color: #000000; /* Similar to OpenAI's clean background */
      color: #ffffff;
        letter-spacing: normal;
    }

    /* Header with logo and contact link */
    header {
      font-size: 17px;
      letter-spacing: -0.17px;
      line-height: 27.999px;
      width: 100%;
    }

    .logo {
      font-weight: 700;
      line-height: 27.999px;
      font-size: 17px;
      color: #ffffff;
      letter-spacing: normal;
      text-decoration: none;
    }

    nav a {
      font-size: 16px;
      text-decoration: none;
      margin: 0px;
      padding: 9px 20px;
      width: 79px;
      height: 40px;
      color: white;
      background-color:rgb(255, 255, 255, 0.12);
      font-weight: 400;
      align-items: center;
      overflow: hidden;
      border-radius: 2.5rem;
      backdrop-filter: blur(3xl);
      transition: all 0.2s ease;
    }

    nav a:hover {
        background-color:rgba(255, 255, 255, 0.2);
    }

    /* Layout container for sidebar and main content */
    .container {
      display: flex;
      min-height: calc(100vh - 70px); /* Adjust based on header height */
    }

    /* Sidebar styling */
    .sidebar {
      width: 220px;
    }

    .sidebar ul {
      list-style: none;
      margin-top: 25px;
    }

    .sidebar ul li {
      margin-bottom: 10px;
     
    }

    .sidebar ul li a {
      font-size: 14px;
      color: white;
      padding: 8px 60px;
      border-radius: 10px;
      padding-left: 0;
      line-height: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .sidebar ul li a:hover {
      background-color: #333333;
    }
  </style>
</head>
<body>
  <!-- Top Navigation -->
  <header>
    <a href="#" class="logo">Arjun Bishnoi</a>
    <nav>
      <a href="mailto:contact@arjunbishnoi.com">Contact</a>
    </nav>
  </header>

  <!-- Page Layout: Sidebar + Main Content -->
  <div class="container">
    <aside class="sidebar">
      <ul>
        <li><a href="#portfolio">Portfolio</a></li>
        <li><a href="#connect">Connect</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#others">Others</a></li>
      </ul>
    </aside>
    <div class="main-content">
      <h1>Stay Tuned</h1>
    </div>
  </div>
</body>
</html>
